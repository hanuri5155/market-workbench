# Storage
CONFIG_PATH=config/config.demo.json
ZONE_LEVELS_PATH=storage/zone_levels.json
EXECUTION_DATA_STORE_PATH=storage/execution_data_store.json
BBANDS_DIR=storage/bbands
SIMULATED_CANDLES_PATH=config/simulated_candles.demo.json
DEMO_MODE=1
STRATEGY_PROVIDER=demo_zone
ENABLE_LIVE_ORDER_PLACEMENT=0

# Indicators
BBANDS_LENGTH=20
BBANDS_MULT=2

# Exchange - Bybit endpoints
BYBIT_BASE_URL=https://api.bybit.com
RECV_WINDOW=5000
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
POSITION_WS_URL=wss://stream.bybit.com/v5/private?max_active_time=10m
EXECUTION_WS_URL=wss://stream.bybit.com/v5/private

# Exchange - Bybit credentials
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# Trading Symbol
SYMBOL=BTCUSDT

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=market_workbench
DB_USER=market_workbench
DB_PASSWORD=

# API / Web
CORS_ORIGINS=https://example.com

# Internal HTTP notify URLs
CANDLE_REST_NOTIFY_URL=http://example-api:8000/internal/candle-rest-confirmed
MTF_MA_SOURCE_NOTIFY_URL=http://example-api:8000/internal/mtf-ma-source-candle
ZONE_DELTA_NOTIFY_URL=http://example-api:8000/internal/zones/delta
ZONE_STATE_SYNC_NOTIFY_URL=http://example-api:8000/internal/zones/state-sync
POSITION_OVERLAY_NOTIFY_URL=http://example-api:8000/internal/position-overlay-event

# Internal WebSocket URLs
STRATEGY_FLAGS_WS_URL=ws://example-api:8000/ws/control
ZONE_STATE_WS_URL=ws://example-api:8000/ws/zones

# Security / 2FA
GOOGLE_OTP_SECRET=

# Telegram
ZONE_BOT_TOKEN=
ZONE_CHAT_ID=
POSITIONS_BOT_TOKEN=
POSITIONS_CHAT_ID=

# Bot runtime
BOT_HEARTBEAT_PATH=/tmp/bot_heartbeat
BOT_HEARTBEAT_SEC=5

# Event loop watchdog (bot/api stall detection)
EVENT_LOOP_WATCHDOG_ENABLED=1
EVENT_LOOP_WATCHDOG_INTERVAL_SEC=1.0
EVENT_LOOP_WATCHDOG_LAG_THRESHOLD_SEC=2.0
EVENT_LOOP_WATCHDOG_LOG_COOLDOWN_SEC=20.0
EVENT_LOOP_WATCHDOG_MAX_TASKS=8
EVENT_LOOP_WATCHDOG_STACK_LIMIT=6

# Images
API_IMAGE=
BOT_IMAGE=
